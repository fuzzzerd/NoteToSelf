---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '@/components/Sidebar.astro';
import signedB from '@/images/signed-b.png';
import '@/styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const fm = Astro.props.frontmatter ?? Astro.props;
const title = fm.title ?? 'Welcome to my site!';
const description =
  fm.description ??
  'Welcome to my blog. This site consists of notes to myself. Hopeful that you find them useful.';

const pageTitle = `${title} - Bross Tribe`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="msvalidate.01" content="8015305C5FC955DE600FEBB07E5FED33" />

    <link rel="alternate" type="application/rss+xml" title="Bross Tribe" href="/rss.xml" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:site_name" content="Bross Tribe" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={signedB.src} />
    <meta property="og:image:width" content="184" />
    <meta property="og:image:height" content="288" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={signedB.src} />

    <ClientRouter />

    <script is:inline>
      // Apply theme before render to prevent flash
      (function () {
        const pref = localStorage.getItem('theme-preference');
        if (pref === 'light' || pref === 'dark') {
          document.documentElement.classList.add(pref);
        }
      })();
    </script>
  </head>
  <body>
    <div id="rightColumn">
      <div id="main-container">
        <slot />
      </div>
    </div>
    <Sidebar />

    <div id="image-lightbox" aria-hidden="true">
      <button id="lightbox-close" aria-label="Close">&times;</button>
      <img src="" alt="" />
    </div>

    <style is:global>
      #image-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.92);
        backdrop-filter: blur(8px);
        cursor: pointer;
        touch-action: none;
        -webkit-tap-highlight-color: transparent;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
      }

      #image-lightbox[aria-hidden='false'] {
        opacity: 1;
        visibility: visible;
      }

      #image-lightbox img {
        max-width: 100%;
        max-height: calc(100vh - 5rem);
        max-height: calc(100dvh - 5rem);
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
        transform: scale(0.95);
        transition: transform 0.3s ease;
      }

      #image-lightbox[aria-hidden='false'] img {
        transform: scale(1);
      }

      #lightbox-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        background: rgba(255, 255, 255, 0.15);
        border: none;
        border-radius: 50%;
        width: 2.75rem;
        height: 2.75rem;
        color: #fff;
        font-size: 1.5rem;
        cursor: pointer;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.9;
        transition: opacity 0.2s ease, background 0.2s ease;
        z-index: 1001;
      }

      #lightbox-close:hover,
      #lightbox-close:active {
        opacity: 1;
        background: rgba(255, 255, 255, 0.25);
      }

      @media (min-width: 768px) {
        #image-lightbox {
          padding: 2rem;
        }

        #lightbox-close {
          top: 1rem;
          right: 1.5rem;
          width: 3rem;
          height: 3rem;
          font-size: 2rem;
        }
      }

      body.lightbox-open {
        overflow: hidden;
        position: fixed;
        left: 0;
        right: 0;
      }
    </style>

    <script>
      function initLightbox() {
        const lightbox = document.getElementById('image-lightbox')!;
        const lightboxImg = lightbox.querySelector('img')!;
        let scrollY = 0;

        function openLightbox(src: string, alt: string) {
          lightboxImg.src = src;
          lightboxImg.alt = alt;
          scrollY = window.scrollY;
          document.body.classList.add('lightbox-open');
          document.body.style.top = `-${scrollY}px`;
          lightbox.setAttribute('aria-hidden', 'false');
        }

        function closeLightbox() {
          lightbox.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('lightbox-open');
          document.body.style.top = '';
          window.scrollTo(0, scrollY);
        }

        document.querySelectorAll('article img').forEach((img) => {
          img.style.cursor = 'pointer';
          img.addEventListener('click', () => {
            openLightbox((img as HTMLImageElement).src, (img as HTMLImageElement).alt);
          });
        });

        lightbox.addEventListener('click', (e) => {
          if (e.target !== lightboxImg) closeLightbox();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && lightbox.getAttribute('aria-hidden') === 'false') {
            closeLightbox();
          }
        });
      }

      // Run on initial load and after each ViewTransitions navigation
      initLightbox();
      document.addEventListener('astro:after-swap', initLightbox);
    </script>
  </body>
</html>
